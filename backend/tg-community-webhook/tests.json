{
  "tests": [
    {
      "name": "Health check",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"status": "tg-community-webhook active"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Telegram update - text message",
      "method": "POST",
      "path": "/",
      "body": {
        "message": {
          "message_id": 1,
          "from": {"id": 123, "is_bot": false, "first_name": "Test", "username": "testuser"},
          "chat": {"id": -1001234567890, "type": "supergroup"},
          "text": "Тестовое сообщение из Telegram"
        }
      },
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Skip bot message",
      "method": "POST",
      "path": "/",
      "body": {
        "message": {
          "message_id": 2,
          "from": {"id": 456, "is_bot": true, "first_name": "Bot"},
          "chat": {"id": -1001234567890, "type": "supergroup"},
          "text": "bot message"
        }
      },
      "expectedStatus": 200,
      "expectedBody": {"ok": true, "skipped": "bot"},
      "bodyMatcher": "partial"
    }
  ]
}
